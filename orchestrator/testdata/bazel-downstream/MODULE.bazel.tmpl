"""Template MODULE.bazel for the M5 downstream-Bazel acceptance test.

The test fills in two placeholders before running bazel:
  __ROOT__       absolute path to the repo root (cmake-to-bazel)
  __MANIFEST__   absolute path to <out>/manifest/converted.json

The use_repo() list pins the two converted FDSDK subset elements; if
the fixture grows, extend the list.
"""

module(name = "downstream", version = "0.0.0")

bazel_dep(name = "rules_cc", version = "0.0.10")
bazel_dep(name = "cmake_to_bazel", version = "0.0.0")

local_path_override(
    module_name = "cmake_to_bazel",
    path = "__ROOT__",
)

converted = use_extension("@cmake_to_bazel//bazel:converted_pkg_repo.bzl", "converted_pkg_repo")
converted.from_manifest(manifest = "__MANIFEST__")
use_repo(
    converted,
    "elem_components_hello",
    "elem_components_uses_hello",
)
