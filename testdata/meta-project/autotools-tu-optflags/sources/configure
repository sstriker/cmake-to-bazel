#!/bin/sh
# Hand-rolled configure. Substitutes @PREFIX@ + @CFLAGS@ into
# Makefile.in. Notably defaults CFLAGS to -O0 -g (debug-style)
# so the per-target `hotloop.o: CFLAGS += -O2` overrides the
# global toolchain's optimization level.

PREFIX=/usr/local
CFLAGS=${CFLAGS:--O0 -g}

while [ $# -gt 0 ]; do
    case "$1" in
        --prefix=*)        PREFIX="${1#--prefix=}" ;;
        --prefix)          PREFIX="$2"; shift ;;
        --exec-prefix=*|--bindir=*|--sbindir=*|--sysconfdir=*|\
        --datadir=*|--includedir=*|--libdir=*|--libexecdir=*|\
        --localstatedir=*|--sharedstatedir=*|--mandir=*|--infodir=*) ;;
        --build=*|--host=*|--target=*) ;;
        *) ;;
    esac
    shift
done

sed -e "s|@PREFIX@|$PREFIX|g" \
    -e "s|@CFLAGS@|$CFLAGS|g" \
    Makefile.in > Makefile

echo "configure: PREFIX=$PREFIX CFLAGS=$CFLAGS"
