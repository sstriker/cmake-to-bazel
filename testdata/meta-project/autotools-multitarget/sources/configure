#!/bin/sh
# Hand-rolled configure for the autotools-multitarget fixture.
# Same canonical autoconf flag surface as autotools-greet's
# configure; substitutes @PREFIX@ + @CFLAGS@ into Makefile.in.

PREFIX=/usr/local
CFLAGS=${CFLAGS:--O2}

while [ $# -gt 0 ]; do
    case "$1" in
        --prefix=*)        PREFIX="${1#--prefix=}" ;;
        --prefix)          PREFIX="$2"; shift ;;
        --exec-prefix=*|--bindir=*|--sbindir=*|--sysconfdir=*|\
        --datadir=*|--includedir=*|--libdir=*|--libexecdir=*|\
        --localstatedir=*|--sharedstatedir=*|--mandir=*|--infodir=*) ;;
        --build=*|--host=*|--target=*) ;;
        *) ;;
    esac
    shift
done

sed -e "s|@PREFIX@|$PREFIX|g" \
    -e "s|@CFLAGS@|$CFLAGS|g" \
    Makefile.in > Makefile

echo "configure: PREFIX=$PREFIX CFLAGS=$CFLAGS"
